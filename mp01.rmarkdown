  scale_y_continuous(labels = scales::percent_format()) +
  labs(
    title = "Racial Composition of California Public Undergraduates Over Time",
    x = "Year",
    y = "Percent of Undergraduate Students",
    fill = "Race/Ethnicity"
  ) +
