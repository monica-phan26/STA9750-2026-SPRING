## 1. DATA ACQUISITION

In this section, we load the dataset and required packages.

```{r}
#' Acquire IPEDS Data for MP#01
#' 
#' This function will acquire and standardize all data for MP#01
#' from IPEDS (https://nces.ed.gov/ipeds/datacenter/DataFiles.aspx)
#' 
#' We're starting in 2010 as the data seems to be reasonably complete 
#' after that point. 
acquire_ipeds_data <- function(start_year=2010, end_year=2024){
    library(tidyverse)
    library(glue)
    
    data_dir <- file.path("data", "mp01")
    
    if(!dir.exists(data_dir)){
        dir.create(data_dir, showWarnings=FALSE, recursive=TRUE)
    }
    
    YEARS <- seq(start_year, end_year)
    
    EFA_ALL <- map(YEARS, function(yy){
        if(yy <= 2022){
            ef_url <- glue("https://nces.ed.gov/ipeds/datacenter/data/EF{yy}A.zip")
            
        } else {
            ef_url <- glue("https://nces.ed.gov/ipeds/data-generator?year={yy}&tableName=EF{yy}A&HasRV=0&type=csv")
        }
        
        ef_file <- file.path(data_dir, glue("ef{yy}a.csv.zip"))
        
        if(!file.exists(ef_file)){
            message(glue("Downloading Enrollment Data for {yy} from {ef_url}"))
            download.file(ef_url, destfile = ef_file, quiet=TRUE, mode="wb")    
        }
        
        read_csv(ef_file, 
                 show_col_types=FALSE) |>
            mutate(year = yy, 
                   # American Indian or Alaskan Native
                   enrollment_m_aian = EFAIANM, 
                   enrollment_f_aian = EFAIANW, 
                   # Asian
                   enrollment_m_asia = EFASIAM, 
                   enrollment_f_asia = EFASIAW, 
                   # Black or African-American, 
                   enrollment_m_bkaa = EFBKAAM, 
                   enrollment_f_bkaa = EFBKAAW, 
                   # Hispanic 
                   enrollment_m_hisp = EFHISPM, 
                   enrollment_f_hisp = EFHISPW, 
                   # Native Hawaiian or Other Pacific Islander 
                   enrollment_m_nhpi = EFNHPIM, 
                   enrollment_f_nhpi = EFNHPIW, 
                   # White
                   enrollment_m_whit = EFWHITM, 
                   enrollment_f_whit = EFWHITW, 
                   # Two or More Races
                   enrollment_m_2mor = EF2MORM, 
                   enrollment_f_2mor = EF2MORW, 
                   # Unknown / Undisclosed Race
                   enrollment_m_unkn = EFUNKNM, 
                   enrollment_f_unkn = EFUNKNW, 
                   # US Non-Resident
                   enrollment_m_nral = EFNRALM, 
                   enrollment_f_nral = EFNRALW, 
            ) |> filter(
                (EFALEVEL %in% c(2, 12)) | (LINE %in% c(1, 15))
                # Per 2024 Data Dictionary, 
                # - EFALEVEL 2 = undergrad 
                # - EFALELVE 12 = grad
                # - Line 1 = first year first time full-time undergrad
                # - Line 15 = first year first time part-time undergrad
            ) |> mutate(level = case_when(
                       EFALEVEL == 2 ~ "all undergrad", 
                       EFALEVEL == 12 ~ "all graduate",
                       LINE %in% c(1, 15) ~ "first year undergrad"
                   )
            ) |>
            select(institution_id = UNITID, 
                   year, 
                   level,
                   starts_with("enrollment_")) |>
            group_by(institution_id, 
                     year, 
                     level) |>
            summarize(across(starts_with("enrollment_"), sum), 
                      .groups = "drop")
        
    }) |> bind_rows()
    
    DESC_ALL <- map(YEARS, function(yy){
        if(yy <= 2022){
            hd_url <- glue("https://nces.ed.gov/ipeds/datacenter/data/HD{yy}.zip")
            
        } else {
            hd_url <- glue("https://nces.ed.gov/ipeds/data-generator?year={yy}&tableName=HD{yy}&HasRV=0&type=csv")
        }
        
        hd_file <- file.path(data_dir, glue("hd{yy}.csv.zip"))
        
        if(!file.exists(hd_file)){
            message(glue("Downloading Institutional Descriptions for {yy} from {hd_url}"))
            download.file(hd_url, destfile = hd_file, quiet=TRUE, mode="wb")    
        }
        
        suppressWarnings(
            read_csv(hd_file, 
                 show_col_types=FALSE, 
                 locale=locale(encoding=if_else(yy==2024, "utf-8", "windows-1252"))) |>
            mutate(year = yy, 
                   INSTNM) |> 
            select(institution_id = UNITID, 
                   institution_name = INSTNM, 
                   state = STABBR, 
                   year)
        )
        
    }) |> bind_rows()
    
    inner_join(EFA_ALL, 
               DESC_ALL, 
               join_by(institution_id == institution_id, 
                       year == year))
}

IPEDS <- acquire_ipeds_data()
```



## 2. DATA CLEANING & PREPARATION

Create a new variable called is_cuny that groups all CUNY schools.
```{r}
IPEDS <- IPEDS |>
  mutate(is_cuny = str_detect(institution_name, "CUNY"))
```

```{r}
IPEDS |>
  filter(is_cuny) |>
  distinct(institution_name) |>
  arrange(institution_name)
```

Create a new variable called is_calpublic that groups schools from the University of California System and the California State System.
```{r}
IPEDS <- IPEDS |>
  mutate(
    is_calpublic =
      str_detect(institution_name, "University of California") |
      str_detect(institution_name, "California State University")
  )
```

```{r}
IPEDS |>
  filter(is_calpublic) |>
  distinct(institution_name) |>
  arrange(institution_name)
```

## 3. EXPLORATORY ANALYSIS

#### INITIAL DATA EXPLORATION

Display the top 10 rows in a table format using the gt library

```{r}
library(tidyverse)
library(gt)
IPEDS |>
  head(10) |>
  gt()
```


For easier viewving, the last four columns are moved to the front, immediately after the third column.


```{r}
IPEDS <- IPEDS |>
  relocate(last_col(offset = 3) : last_col(), .after =3)

IPEDS |>
  slice_head(n = 10) |>
  gt()
```

#### EXPLORATORY QUESTIONS - INLINES VALUES

```{r}
glimpse(IPEDS)
```

```{r}
summary(IPEDS)
```
```{r}
library(skimr)
skim(IPEDS)
```

Number of distinct institutions appear in this dataset is determined using the institution id rather than the institution name because the names may contain inconsistencies or formatting errors.

```{r}
IPEDS |>
  distinct(institution_id, institution_name) |>
  count(institution_id) |>
  filter(n > 1)
```

```{r}
library(scales)
```

There are 8983 distinct institutions in this dataset.

```{r}
IPEDS |>
  summarize(dist_inst_count = comma(n_distinct(institution_id))) |>
  gt()
```


```{r}
IPEDS |>
  filter(str_detect(institution_name, "Baruch"),
         year == 2024,
         level == "all graduate") |>
  summarize(baruch_total_graduate_2024 = sum(across(starts_with("enrollment_")))) |>
  gt() |>
  tab_header(title = "Number of graduate students enrolled at Baruch in 2024") |>
  fmt_number(columns = baruch_total_graduate_2024, decimals = 0)
```


```{r}
IPEDS |>
  filter(str_detect(institution_name, "Baruch"),
         year == 2024,
         level %in% c("all graduate", "all undergrad")) |>
  summarise(baruch_total_2024 = sum(across(starts_with("enrollment_")))) |>
  gt() |>
  tab_header(title = "Total students enrolled at Baruch in 2024") |>
  fmt_number(baruch_total_2024, decimals = 0)

```


```{r}
IPEDS |>
  filter(year == 2019,
         level %in% c("all graduate", "all undergrad")) |>
  group_by(institution_id, institution_name) |>
  summarize(total_female = sum(across(starts_with("enrollment_f"))), .groups = "drop") |>
  arrange(desc(total_female)) |>
  slice(1:2) |>
  gt() |>
  tab_header(title = "Institution with the highest female enrollment in 2019") |>
  fmt_number(columns = total_female, decimals = 0)
```


```{r}
total_students <- IPEDS |>
  filter(
    year == 2024,
    level %in% c("all undergrad", "all graduate")
  ) |>
  group_by(institution_id, institution_name) |>
  summarize(
    total_students = sum(across(starts_with("enrollment_"))),
    .groups = "drop"
  )

first_year_nhpi <- IPEDS |>
  filter(
    year == 2024,
    level == "first year undergrad"
  ) |>
  group_by(institution_id, institution_name) |>
  summarize(
    total_first_year = sum(across(starts_with("enrollment_"))),
    nhpi_total = sum(across(c(enrollment_m_nhpi, enrollment_f_nhpi))),
    nhpi_prop = nhpi_total / total_first_year,
    .groups = "drop"
  )

first_year_nhpi |>
  inner_join(total_students, by = c("institution_id", "institution_name")) |>
  filter(total_students > 1000) |>
  arrange(desc(nhpi_prop)) |>
  slice(1) |>
  select(institution_id, institution_name, nhpi_total, total_first_year, total_students, nhpi_prop) |>
  gt() |>
  tab_header(
    title = "Institution with the highest proportion of nhpi first-year undergraduates (2024)",
    subtitle = "Among institutions with more than 1,000 total students"
  ) |>
  fmt_percent(columns = nhpi_prop, decimals = 2) |>
  fmt_number(columns = c(nhpi_total, total_first_year, total_students), decimals = 0)
  
```
#### EXPLORATORY QUESTIONS - TABLE ANSWER

```{r}
library(dplyr)
```


```{r}
IPEDS |>
  filter(level == "all graduate") |>
  group_by(state) |>
  summarize(
    total_state_graduate = sum(across(starts_with("enrollment_"))),
    .groups = "drop"
  ) |>
  arrange(desc(total_state_graduate)) |>
  slice_head(n = 5) |>
  gt() |>
  fmt_number(columns = total_state_graduate, decimals = 0) |>
  tab_header(title = "5 states had the highest number of graduate students across all institutions located in that state")
```
```{r}
IPEDS |>
  filter(year ==2024,
         level == "first year undergrad",
         is_cuny == TRUE) |>
  group_by(institution_id,institution_name) |>
  summarize(first_year_total = sum(across(starts_with("enrollment_"))), .groups = "drop") |>
  mutate(
    percent_total = first_year_total / sum(first_year_total)
  ) |>
  arrange(desc(first_year_total)) |>
  gt() |>
  tab_header(
    title = "First-year undergraduate enrollment at CUNY Colleges in 2024",
    subtitle = "Absolute enrollment and percent of total CUNY first-year students"
  ) |>
  fmt_number(columns = first_year_total, decimals = 0) |>
  fmt_percent(columns = percent_total, decimals = 2)
```

```{r}
IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    level == "all undergrad"
  ) |>
  group_by(year) |>
  summarize(
    undergrad_total = sum(across(starts_with("enrollment_"))),
    .groups = "drop"
  ) |>
  arrange(year) |>
  mutate(
    pct_change_yoy = (undergrad_total - lag(undergrad_total)) / lag(undergrad_total)
  ) |>
  gt() |>
  tab_header(
    title = "Baruch College Undergraduate Enrollment Over Time",
    subtitle = "Enrollment numbers and year-over-year percent change"
  ) |>
  fmt_number(columns = undergrad_total, decimals = 0) |>
  fmt_percent(columns = pct_change_yoy, decimals = 2)
```
```{r}
IPEDS |>
  filter(
    year %in% c(2010, 2020),
    level == "all undergrad"
  ) |>
  mutate(
    total_students = rowSums(across(starts_with("enrollment_"))),
    white_students = enrollment_m_whit + enrollment_f_whit,
    white_fraction = white_students / total_students
  ) |>
  filter(total_students > 1000) |>
  select(institution_id, institution_name, year, white_fraction) |>
  pivot_wider(
    names_from = year,
    values_from = white_fraction
  ) |>
  mutate(
    change_2010_2020 = `2020` - `2010`
  ) |>
  arrange(change_2010_2020) |>
  slice_head(n = 5) |>
  gt() |>
  tab_header(
    title = "Top 5 institutions with the largest decrease in fraction of white students from 2010 to 2020"
  ) |>
  fmt_percent(columns = c(`2010`, `2020`, change_2010_2020), decimals = 2)
```



```{r}
IPEDS |>
  filter(
    year %in% c(2010, 2024),
    level == "all undergrad"
  ) |>
  mutate(
    total_students = rowSums(across(starts_with("enrollment_"))),
    female_students = rowSums(across(starts_with("enrollment_f_"))),
    female_fraction = female_students / total_students
  ) |>
  group_by(state, year) |>
  summarize(
    female_fraction = sum(female_students) / sum(total_students),
    .groups = "drop"
  ) |>
  pivot_wider(
    names_from = year,
    values_from = female_fraction
  ) |>
  mutate(
    change_2010_2024 = `2024` - `2010`
  ) |>
  arrange(desc(change_2010_2024)) |>
  slice_head(n = 3) |>
  gt() |>
  tab_header(
    title = "Top 3 States with the largest increase in female undergraduate fraction from 2010 to 2024"
  ) |>
  fmt_percent(columns = c(`2010`, `2024`, change_2010_2024), decimals = 2)
```
## 4. OP-ED



```{r}
IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    year == 2024,
    level == "all undergrad"
  ) |>
  summarize(
    total_undergrad = sum(across(starts_with("enrollment_"))),
    
    female_total = sum(across(starts_with("enrollment_f_"))),
    male_total = sum(across(starts_with("enrollment_m_"))),
    
    pct_female = female_total / total_undergrad,
    pct_male = male_total / total_undergrad,
    
    pct_white = sum(enrollment_m_whit + enrollment_f_whit) / total_undergrad,
    pct_asian = sum(enrollment_m_asia + enrollment_f_asia) / total_undergrad,
    pct_hispanic = sum(enrollment_m_hisp + enrollment_f_hisp) / total_undergrad,
    pct_black = sum(enrollment_m_bkaa + enrollment_f_bkaa) / total_undergrad,
    
    .groups = "drop"
  ) |>
  gt() |>
  tab_header(
    title = "Baruch College Undergraduate Student Body Composition (2024)"
  ) |>
  fmt_number(columns = total_undergrad, decimals = 0) |>
  fmt_percent(
    columns = c(pct_female, pct_male, pct_white, pct_asian, pct_hispanic, pct_black),
    decimals = 2
  )
```

```{r}
IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    level == "first year undergrad"
  ) |>
  group_by(year) |>
  summarize(
    first_year_total = sum(across(starts_with("enrollment_"))),
    .groups = "drop"
  ) |>
  arrange(year) |>
  mutate(
    pct_change_yoy = (first_year_total - lag(first_year_total)) / lag(first_year_total)
  ) |>
  gt() |>
  tab_header(
    title = "Baruch College First-Year Undergraduate Enrollment Over Time",
    subtitle = "Year-over-year comparison of entering first-time students"
  ) |>
  fmt_number(columns = first_year_total, decimals = 0) |>
  fmt_percent(columns = pct_change_yoy, decimals = 2)
```

```{r}
IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    level == "all undergrad"
  ) |>
  group_by(year) |>
  summarize(
    asian_students = sum(enrollment_m_asia + enrollment_f_asia),
    .groups = "drop"
  ) |>
  arrange(year) |>
  mutate(
    pct_change_yoy = (asian_students - lag(asian_students)) / lag(asian_students)
  ) |>
  gt() |>
  tab_header(
    title = "Asian Undergraduate Enrollment at Baruch College",
    subtitle = "Absolute numbers and year-over-year percent change"
  ) |>
  fmt_number(columns = asian_students, decimals = 0) |>
  fmt_percent(columns = pct_change_yoy, decimals = 2)
```
```{r}
IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    level == "all undergrad"
  ) |>
  group_by(year) |>
  summarize(
    total_students = sum(across(starts_with("enrollment_"))),
    
    female_students = sum(across(starts_with("enrollment_f_"))),
    white_students = sum(enrollment_m_whit + enrollment_f_whit),
    asian_students = sum(enrollment_m_asia + enrollment_f_asia),
    hisp_students = sum(enrollment_m_hisp + enrollment_f_hisp),
    black_students = sum(enrollment_m_bkaa + enrollment_f_bkaa),
    
    pct_female = female_students / total_students,
    pct_white = white_students / total_students,
    pct_asian = asian_students / total_students,
    pct_hisp = hisp_students / total_students,
    pct_black = black_students / total_students,
    
    .groups = "drop"
  ) |>
  arrange(year) |>
  mutate(
    yoy_total_change = (total_students - lag(total_students)) / lag(total_students)
  ) |>
  gt() |>
  tab_header(
    title = "Year-over-Year Demographic Composition of Baruch Undergraduates",
    subtitle = "Total enrollment and demographic shares"
  ) |>
  fmt_number(columns = total_students, decimals = 0) |>
  fmt_percent(
    columns = c(pct_female, pct_white, pct_asian, pct_hisp, pct_black, yoy_total_change),
    decimals = 2
  )
```

```{r}
library(tidyverse)

baruch_race <- IPEDS |>
  filter(
    str_detect(institution_name, "Baruch"),
    level == "all undergrad"
  ) |>
  group_by(year) |>
  summarize(
    total_students = sum(across(starts_with("enrollment_"))),
    
    white = sum(enrollment_m_whit + enrollment_f_whit),
    asian = sum(enrollment_m_asia + enrollment_f_asia),
    hispanic = sum(enrollment_m_hisp + enrollment_f_hisp),
    black = sum(enrollment_m_bkaa + enrollment_f_bkaa),
    
    .groups = "drop"
  ) |>
  pivot_longer(
    cols = c(white, asian, hispanic, black),
    names_to = "race",
    values_to = "students"
  ) |>
  mutate(
    pct = students / total_students,
    pct_label = scales::percent(pct, accuracy = 0.1)
  )

ggplot(baruch_race, aes(x = factor(year), y = pct, fill = race)) +
  geom_col() +
  geom_text(
    aes(label = pct_label),
    position = position_stack(vjust = 0.5),
    size = 3
  ) +
  scale_y_continuous(labels = scales::percent_format()) +
  labs(
    title = "Racial Composition of Baruch Undergraduate Students Over Time",
    x = "Year",
    y = "Percent of Undergraduate Students",
    fill = "Race/Ethnicity"
  ) +
  theme_minimal()
```

```{r}
IPEDS |>
  filter(
    is_calpublic == TRUE,
    level == "all undergrad"
  ) |>
  group_by(year) |>
